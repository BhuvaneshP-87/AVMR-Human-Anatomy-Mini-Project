  m_Script: {fileID: 11500000, guid: cc7a4d161fae74300954a6035ea9af53, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AVMR.AnatomyViewer.AnatomyInfoPanelController
  titleText: {fileID: 1405780800}
  bodyText: {fileID: 1790545136}
  audioSource: {fileID: 1695198720}
  narrations:
  - title: Skin Layer
    body: Protective outer body covering.
    clip: {fileID: 8300000, guid: c1c5a23e99cec421da73d52dc9d96967, type: 3}
  - title: Skeleton Layer
    body: Rigid framework supporting the body.
    clip: {fileID: 8300000, guid: 7ccb9fc1992f84daea05b094292864c7, type: 3}
  - title: Muscle Layer
    body: Muscles powering movement and posture.
    clip: {fileID: 8300000, guid: 5aacc1679b2874668b152981fb740916, type: 3}
  - title: Anatomy Layer
    body: Integrated view of major internal systems.
    clip: {fileID: 8300000, guid: 9b3f6928a5c1244a0a991b272f19e90c, type: 3}
  - title: Heart Organ
    body: Pumps blood through the body.
    clip: {fileID: 8300000, guid: 25d4f60efc7974ecdaa31256f619522b, type: 3}
  - title: Cranium
    body: Protects the brain.
    clip: {fileID: 8300000, guid: f3e2712b55add42d6bfb97d6c9d31882, type: 3}
  - title: Mandible
    body: Lower jaw for chewing.
    clip: {fileID: 8300000, guid: 33e039b6ba33b4773b85af88f79f728f, type: 3}
  - title: Clavicle
    body: Braces the shoulder.
    clip: {fileID: 8300000, guid: 114ca465c4cb641bf8ba2621a3771529, type: 3}
  - title: Scapula
    body: Shoulder blade anchor.
    clip: {fileID: 8300000, guid: 2dbf5f48b21184787b37d758cbaf635c, type: 3}
  - title: Rib Cage
    body: Protects heart and lungs.
    clip: {fileID: 8300000, guid: f85f3a81a77954f43b3b24adf79f1769, type: 3}
  - title: Spine
    body: Supports trunk and spinal cord.
    clip: {fileID: 8300000, guid: 515f7067a7d7b4c188ef65673876e423, type: 3}
  - title: Pelvis
    body: Transfers body weight.
    clip: {fileID: 8300000, guid: d5ba4f653dbf543ce956baf0b5493995, type: 3}
  - title: Humerus
    body: Upper arm bone.
    clip: {fileID: 8300000, guid: 99cde7015704b4c3193530ac17ce203b, type: 3}
  - title: Radius
    body: Thumb-side forearm bone.
    clip: {fileID: 8300000, guid: 7c059eac41daf45b98dca10f2cada1a4, type: 3}
  - title: Ulna
    body: Little-finger forearm bone.
    clip: {fileID: 8300000, guid: 08282f7c111cc48b39a3a53f995e3f15, type: 3}
  - title: Carpals
    body: Wrist bones for mobility.
    clip: {fileID: 8300000, guid: 44ad0e4df8d534c479114cb59ad52590, type: 3}
  - title: Femur
    body: Primary thigh support bone.
    clip: {fileID: 8300000, guid: 911907f5e30d449399633fb9fea27aca, type: 3}
  - title: Patella
    body: Shields the knee joint.
    clip: {fileID: 8300000, guid: 5417aa0b450fb4c1ab855ed0bca90c75, type: 3}
  - title: Tibia
    body: Main weight-bearing shin bone.
    clip: {fileID: 8300000, guid: ee950f73c54d84accb3254ee1eb65eb8, type: 3}
  - title: Fibula
    body: Stabilizes the outer leg.
    clip: {fileID: 8300000, guid: 632279ff92ff84651a9e85efe5b0a256, type: 3}
  - title: Tarsals
    body: Ankle bones aid balance.
    clip: {fileID: 8300000, guid: 040e1eeee92d2453eb23771d2c786917, type: 3}
  - title: Metatarsals
    body: Bridge ankle to toes.
    clip: {fileID: 8300000, guid: 904a8fcc8e3064ed08c6c4fd5b400917, type: 3}
  - title: Phalanges
    body: Finger and toe bones.
    clip: {fileID: 8300000, guid: d0320c2320c844be1b8333bba846ed4a, type: 3}
